{
  "$id": "formation-review-case.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "caseId": {
      "type": "string"
    },
    "currentModeExpectedInteractions": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "expectedExclusions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "expectedInactiveTraits": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "formation": {
      "type": "object"
    },
    "formationDragonIds": {
      "type": "object"
    },
    "importantFalsePositivesToPrevent": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "label": {
      "type": "string"
    },
    "previewModeExpectedInteractions": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "relevantEvidenceIds": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "reviewerNotes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "reviewStatus": {
      "enum": [
        "pending",
        "confirmed",
        "contradicted",
        "needs-correction"
      ]
    }
  },
  "required": [
    "caseId",
    "label",
    "formation",
    "formationDragonIds",
    "currentModeExpectedInteractions",
    "previewModeExpectedInteractions",
    "expectedInactiveTraits",
    "expectedExclusions",
    "importantFalsePositivesToPrevent",
    "relevantEvidenceIds",
    "reviewStatus",
    "reviewerNotes"
  ],
  "type": "object"
}
