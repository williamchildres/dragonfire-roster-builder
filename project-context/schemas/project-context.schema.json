          "rarity": {
            "enum": [
              "Legendary",
              "Epic",
              "Rare"
            ]
          },
          "rosterSourceStatus": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "source": {
            "properties": {
              "branch": {
                "type": "string"
              },
              "commit": {
                "type": "string"
              },
              "databaseVersion": {
